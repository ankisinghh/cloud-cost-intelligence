PORT=5000
CLIENT_ORIGIN=http://localhost:5173
MONGO_URI=mongodb://localhost:27017/insightdash
JWT_SECRET=change_me_to_a_long_random_string
COOKIE_NAME=insightdash_token
NODE_ENV=development

# Cloud analysis toggle (default: local in-process worker)
USE_CLOUD_ANALYSIS=false
# CLOUD_ANALYSIS_URL=https://your-lambda.example.com/analyze
# CLOUD_ANALYSIS_TOKEN=shared-secret